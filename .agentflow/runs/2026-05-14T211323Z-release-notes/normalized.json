{
  "version": "1",
  "name": "release-notes",
  "description": "Gera release notes a partir de uma lista de mudanças.",
  "inputs": {
    "changes": {
      "type": "array",
      "required": true
    },
    "version": {
      "type": "string",
      "required": true
    }
  },
  "defaults": {
    "timeout": 300,
    "working_dir": "."
  },
  "execution": {
    "max_concurrency": 2,
    "fail_fast": true,
    "output_dir": ".agentflow/runs"
  },
  "nodes": [
    {
      "id": "normalize_changes",
      "kind": "transform",
      "sandbox": {},
      "capture": {},
      "operation": "json_stringify",
      "input": "${inputs.changes}"
    },
    {
      "id": "draft_release_notes",
      "kind": "agent",
      "depends_on": ["normalize_changes"],
      "provider": "codex",
      "prompt": "Gere release notes para a versão ${inputs.version}.\n\nMudanças:\n${nodes.normalize_changes.output}\n\nResponda somente com JSON.\n",
      "system": "You are writing release notes only.\nDo not run shell commands.\nDo not inspect the repository.\nReturn only valid JSON matching the schema.\n",
      "sandbox": {},
      "output_schema": {
        "additionalProperties": false,
        "properties": {
          "breaking_changes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "corrections": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "highlights": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "improvements": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "summary": {
            "type": "string"
          },
          "validation": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "summary",
          "highlights",
          "breaking_changes",
          "improvements",
          "corrections",
          "validation"
        ],
        "type": "object"
      },
      "capture": {}
    },
    {
      "id": "final_check",
      "kind": "agent",
      "depends_on": ["draft_release_notes"],
      "provider": "codex",
      "prompt": "Revise as release notes abaixo para clareza e precisão.\n\n${nodes.draft_release_notes.output}\n\nResponda somente com JSON.\n",
      "system": "You are reviewing release notes only.\nDo not run shell commands.\nDo not inspect the repository.\nReturn only valid JSON matching the schema.\n",
      "sandbox": {},
      "output_schema": {
        "additionalProperties": false,
        "properties": {
          "breaking_changes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "corrections": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "highlights": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "improvements": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "summary": {
            "type": "string"
          },
          "validation": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "summary",
          "highlights",
          "breaking_changes",
          "improvements",
          "corrections",
          "validation"
        ],
        "type": "object"
      },
      "capture": {}
    }
  ]
}
