            "breaking_changes",
            "improvements",
            "corrections",
            "validation"
          ],
          "type": "object"
        },
        "capture": {}
      },
      "dependencies": ["draft_release_notes"],
      "dependents": [],
      "index": 2
    },
    "normalize_changes": {
      "spec": {
        "id": "normalize_changes",
        "kind": "transform",
        "sandbox": {},
        "capture": {},
        "operation": "json_stringify",
        "input": "${inputs.changes}"
      },
      "dependencies": null,
      "dependents": ["draft_release_notes"],
      "index": 0
    }
  },
  "edges": [
    {
      "from": "normalize_changes",
      "to": "draft_release_notes"
    },
    {
