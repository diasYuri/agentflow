        "system": "You are reviewing release notes only.\nDo not run shell commands.\nDo not inspect the repository.\nReturn only valid JSON matching the schema.\n",
        "sandbox": {},
        "output_schema": {
          "additionalProperties": false,
          "properties": {
            "breaking_changes": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "corrections": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "highlights": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "improvements": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "summary": {
              "type": "string"
            },
            "validation": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "required": [
            "summary",
