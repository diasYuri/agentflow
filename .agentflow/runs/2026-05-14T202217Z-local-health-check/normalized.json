{
  "version": "1",
  "name": "local-health-check",
  "description": "Executa checagens locais rápidas sem depender de Codex.",
  "vars": {
    "test_command": "go test ./..."
  },
  "defaults": {
    "timeout": 120,
    "working_dir": "."
  },
  "execution": {
    "max_concurrency": 2,
    "fail_fast": true,
    "output_dir": ".agentflow/runs"
  },
  "nodes": [
    {
      "id": "list_module",
      "kind": "bash",
      "sandbox": {},
      "command": "go list ./...\n",
      "capture": {
        "stdout": true,
        "stderr": true,
        "exit_code": true
      }
    },
    {
      "id": "run_tests",
      "kind": "bash",
      "depends_on": ["list_module"],
      "continue_on_error": true,
      "sandbox": {},
      "command": "${vars.test_command}\n",
      "capture": {
        "stdout": true,
        "stderr": true,
        "exit_code": true
      }
    },
    {
      "id": "tests_failed",
      "kind": "noop",
      "depends_on": ["run_tests"],
      "when": "${nodes.run_tests.exit_code} != 0",
      "sandbox": {},
      "capture": {}
    },
    {
      "id": "done",
      "kind": "noop",
      "depends_on": ["run_tests", "tests_failed"],
      "sandbox": {},
      "capture": {}
    }
  ]
}
