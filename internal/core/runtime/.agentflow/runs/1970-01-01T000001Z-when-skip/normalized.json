{
  "version": "1",
  "name": "when-skip",
  "defaults": {},
  "execution": {},
  "nodes": [
    {
      "id": "test",
      "kind": "bash",
      "continue_on_error": true,
      "sandbox": {},
      "command": "exit 0",
      "capture": {}
    },
    {
      "id": "fix",
      "kind": "noop",
      "depends_on": [
        "test"
      ],
      "when": "${nodes.test.exit_code} != 0",
      "sandbox": {},
      "capture": {}
    }
  ]
}
